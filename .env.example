DATABASE_URL=postgres://user:password@host:5432/database
# Alternativa aceita pelo app, comum em algumas integrações:
# POSTGRES_URL=postgres://user:password@host:5432/database
ADMIN_PIN=troque-este-pin

# Opcional: fonte pública do calendário e cache em milissegundos.
MATCHES_API_URL=https://raw.githubusercontent.com/openfootball/worldcup.json/master/2026/worldcup.json
MATCHES_CACHE_MS=3600000

# Use apenas com Postgres local sem SSL.
# POSTGRES_DISABLE_SSL=true
